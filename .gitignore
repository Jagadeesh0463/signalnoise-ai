# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ── Data (never commit raw or processed documents) ────────────────────────────
data/raw/
data/processed/

# ── ChromaDB (vector store lives locally) ─────────────────────────────────────
chroma/
*.chroma

# ── SQLite database ───────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Streamlit ────────────────────────────────────────────────────────────────
