.streamlit/secrets.toml

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── pytest ────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
