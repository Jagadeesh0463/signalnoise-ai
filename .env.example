# SignalNoise AI — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to GitHub.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Groq API (demo only — enterprise uses Ollama) ─────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── Data Paths ────────────────────────────────────────────────
# Defaults write to /tmp — writable on both Streamlit Cloud and local dev.
# Override with local paths if you want data to persist across restarts.
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SAMPLE_DATA_DIR=data/sample

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_DB_PATH=data/processed/chroma

# ── SQLite ────────────────────────────────────────────────────
SQLITE_DB_PATH=data/processed/signalnoise.db

# ── Quality Gate Thresholds ───────────────────────────────────
MIN_WORD_COUNT=50
MAX_WORD_COUNT=100000
MAX_SINGLE_TOKEN_RATIO=0.60
ENGLISH_MARKER_THRESHOLD=0.02

# ── Signal Detection ──────────────────────────────────────────
MIN_DOCS_FOR_BERTOPIC=10
MIN_TOPIC_SIZE=2

# ── Privacy ───────────────────────────────────────────────────
SPACY_MODEL=en_core_web_sm
MIN_GROUP_SIZE=5

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
